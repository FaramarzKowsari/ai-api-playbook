{
  "name": "search_book_catalog",
  "description": "Search the authorized book catalog by topic and language. Return metadata only.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "query": {"type": "string", "minLength": 2, "maxLength": 200},
      "language": {"type": "string", "enum": ["en", "fa", "tr", "es"]},
      "limit": {"type": "integer", "minimum": 1, "maximum": 20}
    },
    "required": ["query", "language"],
    "additionalProperties": false
  }
}
